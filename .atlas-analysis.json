    "GET /description.xml",
    "POST /upnp/control/ContentDirectory",
    "POST /upnp/event/ContentDirectory",
    "ContentDirectory#Browse",
    "ContentDirectory#GetSortCapabilities",
    "ContentDirectory#GetSearchCapabilities",
