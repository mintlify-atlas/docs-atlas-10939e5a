  "keyFeatures": [
    "UPnP/DLNA MediaServer:1 device advertisement via SSDP",
    "ContentDirectory:1 service with Browse, GetSortCapabilities, and GetSearchCapabilities actions",
    "SOAP over HTTP for UPnP service control",
    "Edge.js templating for XML response generation",
    "Auto-detection of local IPv4 network address",
    "JSON-driven media gallery for video content",
    "Zero external runtime dependencies beyond cheerio and edge.js"
  ],
  "publicApiSurface": [
    "SsdpMessage",
    "SsdpIncomingMessage",
    "SsdpOutgoingMessage",
    "SoapRequest",
